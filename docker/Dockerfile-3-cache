# =============================================================================
# Dockerfile-3-cache: Ottimizzazione build con cache mount e ordinamento layer
# =============================================================================
#
# Introduzione:
# - Usiamo BUILDKIT --mount=type=cache per riciclare le dipendenze Maven tra build
#   (non serve riscaricarle da internet a ogni build)
# - Ordiniamo i COPY per sfruttare al massimo il caching di Docker:
#   * pom.xml e mvnw prima (cambiano raramente)
#   * src/ dopo (cambia frequentemente con il codice)
#
# Separiamo inoltre il layered JAR di Spring Boot nei quattro layer nativi:
#   dependencies          dipendenze release, cambiano raramente
#   spring-boot-loader    launcher di Spring Boot
#   snapshot-dependencies dipendenze SNAPSHOT
#   application           classi e risorse dell'app, cambiano spesso
# In questo modo una modifica al codice non ridistribuisce tutte le dipendenze.
#
# =============================================================================

# -----------------------------------------------------------------------------
# STAGE 1: Build
# -----------------------------------------------------------------------------
FROM eclipse-temurin:25-jdk AS builder

WORKDIR /build

# Copio solo wrapper e pom.xml: questi cambiano raramente, quindi stare in alto
# sfrutta la cache Docker per le build successive (se non hai cambiato pom.xml,
# questo layer e tutti quelli successivi fino al COPY src sono in CACHE)
COPY mvnw pom.xml ./
COPY .mvn .mvn/

# BuildKit cache mount su ~/.m2: le dipendenze scaricate qui vengono riciclate
# tra build successive (non serve riscaricarle da internet)
RUN --mount=type=cache,target=/root/.m2 ./mvnw dependency:go-offline -DskipTests

# Ora copio il codice sorgente (questo e' il layer che cambia di piu')
COPY src/ ./src/

# Build del JAR: Spring Boot 4 genera un layered JAR internamente
RUN --mount=type=cache,target=/root/.m2 ./mvnw clean package -DskipTests --batch-mode

# Il jarmode "tools" incluso nel JAR estrae fisicamente i layer e il launcher.
# I layer restano in directory separate per poterli copiare uno alla volta nello
# stage runtime e ottenere layer Docker con frequenze di invalidazione diverse.
RUN java -Djarmode=tools \
        -jar target/docker-optimization-showcase-0.0.1-SNAPSHOT.jar \
        extract --layers --launcher --destination /build/layers


# -----------------------------------------------------------------------------
# STAGE 2: Runtime
# -----------------------------------------------------------------------------
FROM eclipse-temurin:25-jre

WORKDIR /app

# L'ordine va dal contenuto più stabile a quello che cambia più spesso.
# Ogni COPY genera un layer Docker distinto: modificare una classe applicativa
# invalida solo l'ultimo, lasciando riutilizzabili dipendenze e loader.
COPY --from=builder /build/layers/dependencies/ ./
COPY --from=builder /build/layers/spring-boot-loader/ ./
COPY --from=builder /build/layers/snapshot-dependencies/ ./
COPY --from=builder /build/layers/application/ ./

EXPOSE 8080

ENTRYPOINT ["java", "org.springframework.boot.loader.launch.JarLauncher"]
