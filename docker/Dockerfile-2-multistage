# Build stage: JDK completo per compilare
FROM eclipse-temurin:25-jdk AS builder

WORKDIR /build

COPY mvnw pom.xml ./
COPY .mvn .mvn/

# Scarico le dipendenze Maven (si mette in cache)
RUN ./mvnw dependency:go-offline -DskipTests

# Ora copio il codice sorgente
COPY src/ ./src/

# Build del JAR
RUN ./mvnw clean package -DskipTests --batch-mode


# Runtime stage: solo JRE per eseguire
FROM eclipse-temurin:25-jre

WORKDIR /app

# Copio SOLO il JAR dal builder (non tutto il resto)
COPY --from=builder /build/target/docker-optimization-showcase-0.0.1-SNAPSHOT.jar app.jar

EXPOSE 8080

CMD ["java", "-jar", "app.jar"]
